{
  "name": "jeuxcracks-launcher",
  "version": "2.0.5",
  "description": "Le launcher officiel JeuxCracks.fr",
  "author": "JeuxCracks",
  "main": "dist-electron/main/index.js",
  "keywords": [
    "launcher",
    "electron",
    "vue",
    "vite",
    "torrents"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "publish": "vite build && electron-builder --publish always",
    "dist": "yarn build",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/systeminformation": "^3.54.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.15",
    "electron": "^25.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.28",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.1",
    "vue": "^3.2.47",
    "webtorrent-hybrid": "^5.0.2"
  },
  "dependencies": {
    "@heroicons/vue": "^2.1.1",
    "@kyvg/vue3-notification": "^3.2.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.14.10",
    "7zip-bin": "^5.2.0",
    "adm-zip": "^0.5.16",
    "aria2": "^4.1.2",
    "chart.js": "^4.4.2",
    "decompress": "^4.2.1",
    "dompurify": "^3.3.2",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.1",
    "electron-root-path": "^1.1.0",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "node-7z": "^3.0.0",
    "node-machine-id": "^1.1.12",
    "nodejs-file-downloader": "^4.12.1",
    "pinia": "^2.1.6",
    "pinia-plugin-persistedstate": "^3.2.0",
    "sudo-prompt": "^9.2.1",
    "swiper": "^11.1.0",
    "systeminformation": "^5.30.7",
    "vue-final-modal": "^4.5.4",
    "vue-router": "^4.2.4",
    "vue-tsc": "^2.0.7",
    "webtorrent": "1.9.7"
  },
  "engines": {
    "node": ">=16.0.0 <19.0.0",
    "npm": ">=7.10.0 <10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wasmata/jeuxcracks_app.git"
  },
  "build": {
    "productName": "JeuxCracks Launcher",
    "appId": "fr.jeuxcracks.launcher",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "HSKNinja",
        "repo": "jeuxcracks_app_releases",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist-electron",
      "dist"
    ],
    "win": {
      "icon": "assets/logo.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "installerHeaderIcon": "assets/logo.ico",
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "artifactName": "JeuxCracks-Setup.${ext}"
    },
    "extraResources": [
      "downloads/**",
      "assets/**"
    ]
  }
}
